<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="using:GlobalDataCreatorETL.UI.Views.Controls"
       xmlns:vm="using:GlobalDataCreatorETL.UI.ViewModels"
       x:Class="GlobalDataCreatorETL.UI.Views.MainWindow"
       Title="Global DataCreator ETL"
       Width="1100" Height="740"
       MinWidth="960" MinHeight="640"
       WindowStartupLocation="CenterScreen"
       Background="#1A2235"
       ExtendClientAreaToDecorationsHint="True"
       ExtendClientAreaChromeHints="NoChrome"
       ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="Auto,0,*,Auto">

        <!-- ═══ Row 0: Application Header / Custom Title Bar ════════════════ -->
        <!--  Height="50" is explicit so the Grid resolves row-0 size on the    -->
        <!--  very first measure pass, before any async DWM decoration callback. -->
        <Border Grid.Row="0" Height="50"
                PointerPressed="TitleBar_PointerPressed"
                DoubleTapped="TitleBar_DoubleTapped">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#141D30" Offset="0" />
                    <GradientStop Color="#1C1840" Offset="0.6" />
                    <GradientStop Color="#201538" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left: App identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            Margin="16 0 0 0" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Foreground="#F59E0B" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Global DataCreator ETL"
                                   FontSize="15" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Trade Data Extraction &amp; Excel Generation"
                                   FontSize="10" Foreground="#607888" />
                    </StackPanel>
                </StackPanel>
                <!-- Right: Window controls (Height matches header so no Stretch needed) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0">
                    <Button Classes="WinCtrlBtn" Click="MinimizeButton_Click"
                            ToolTip.Tip="Minimize">
                        <TextBlock Text="&#x2212;" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button x:Name="MaximizeButton" Classes="WinCtrlBtn" Click="MaximizeButton_Click"
                            ToolTip.Tip="Maximize">
                        <TextBlock Text="&#x25A1;" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button Classes="WinCtrlBtn CloseBtn" Click="CloseButton_Click"
                            ToolTip.Tip="Close">
                        <TextBlock Text="&#x2715;" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Row 1: Menu Bar (hidden) ══════════════════════════════════ -->

        <!-- ═══ Row 2: Main Content ══════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="4 2">

            <!-- ── Group 1: Filter Parameters ───────────────────────── -->
            <Border Grid.Row="0" Classes="Card" Padding="0" Margin="0 0 0 8" ClipToBounds="True">
                <Grid RowDefinitions="Auto,2,Auto">

                    <!-- Header Banner -->
                    <Border Grid.Row="0" Background="#17263C" Padding="14 10">
                        <Grid ColumnDefinitions="Auto,10,Auto">
                            <Viewbox Grid.Column="0" Width="20" Height="20"
                                     VerticalAlignment="Center" Stretch="Uniform">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#5B9BF5" Data="M4 4H20L14 11V17L10 17V11Z" />
                                </Canvas>
                            </Viewbox>
                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                <TextBlock Text="FILTER PARAMETERS"
                                           FontSize="13" FontWeight="Bold" LetterSpacing="1.4"
                                           Foreground="#D4E8F8"
                                           FontFamily="Segoe UI, Inter, sans-serif" />
                                <TextBlock Text="Date range, trade filters &amp; output configuration"
                                           FontSize="9" LetterSpacing="0.4"
                                           Foreground="#3A566E"
                                           FontFamily="Segoe UI, Inter, sans-serif" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Gradient accent line -->
                    <Border Grid.Row="1" Height="2">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                <GradientStop Color="#4A8EE8" Offset="0" />
                                <GradientStop Color="#2C5CB0" Offset="0.4" />
                                <GradientStop Color="#1E2E44" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Fields content -->
                    <Border Grid.Row="2" Background="#131D2C" Padding="14 12">
                        <controls:InputFieldsControl />
                    </Border>

                </Grid>
            </Border>

            <!-- ── Group 2: Control, Output &amp; Status ────────────── -->
            <controls:ControlsPanelControl Grid.Row="1" />

        </Grid>

        <!-- ═══ Row 3: Footer ════════════════════════════════════════════════ -->
        <controls:FooterControl Grid.Row="3" />

    </Grid>

</Window>
