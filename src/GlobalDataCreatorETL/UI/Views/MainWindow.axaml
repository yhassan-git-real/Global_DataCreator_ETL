<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="using:GlobalDataCreatorETL.UI.Views.Controls"
       xmlns:vm="using:GlobalDataCreatorETL.UI.ViewModels"
       x:Class="GlobalDataCreatorETL.UI.Views.MainWindow"
       Title="Global DataCreator ETL"
       Width="1100" Height="740"
       MinWidth="960" MinHeight="640"
       WindowStartupLocation="CenterScreen"
       Background="#F1F5F9"
       ExtendClientAreaToDecorationsHint="True"
       ExtendClientAreaChromeHints="NoChrome"
       ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="Auto,0,*,Auto">

        <!-- ═══ Row 0: Application Header / Custom Title Bar ════════════════ -->
        <!--  Height="50" is explicit so the Grid resolves row-0 size on the    -->
        <!--  very first measure pass, before any async DWM decoration callback. -->
        <Border Grid.Row="0" Height="50"
                PointerPressed="TitleBar_PointerPressed"
                DoubleTapped="TitleBar_DoubleTapped">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#0F172A" Offset="0" />
                    <GradientStop Color="#1E3A5F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto">
                <!-- Left: App identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            Margin="16 0 0 0" VerticalAlignment="Center">
                    <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Foreground="White" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Global DataCreator ETL"
                                   FontSize="15" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Trade Data Extraction &amp; Excel Generation"
                                   FontSize="10" Foreground="#94A3B8" />
                    </StackPanel>
                </StackPanel>
                <!-- Right: Window controls (Height matches header so no Stretch needed) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="0">
                    <Button Classes="WinCtrlBtn" Click="MinimizeButton_Click"
                            ToolTip.Tip="Minimize">
                        <TextBlock Text="&#x2212;" FontSize="16" FontWeight="Bold"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button x:Name="MaximizeButton" Classes="WinCtrlBtn" Click="MaximizeButton_Click"
                            ToolTip.Tip="Maximize">
                        <TextBlock Text="&#x25A1;" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button Classes="WinCtrlBtn CloseBtn" Click="CloseButton_Click"
                            ToolTip.Tip="Close">
                        <TextBlock Text="&#x2715;" FontSize="13"
                                   VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Row 1: Menu Bar (hidden) ══════════════════════════════════ -->

        <!-- ═══ Row 2: Main Content ══════════════════════════════════════════ -->
        <Grid Grid.Row="2" RowDefinitions="Auto,*" Margin="16 10">

            <!-- ── Group 1: Filter Parameters ───────────────────────── -->
            <Border Grid.Row="0" Classes="Card" Margin="0 0 0 8">
                <StackPanel Spacing="0">
                <StackPanel Classes="CardHeaderRow">
                        <Viewbox Classes="HeaderIcon">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#64748B" Data="M4 4H20L14 11V17L10 17V11Z" />
                            </Canvas>
                        </Viewbox>
                        <TextBlock Classes="CardHeader" Text="Filter Parameters" />
                    </StackPanel>
                    <Border Classes="Divider" />
                    <controls:InputFieldsControl />
                </StackPanel>
            </Border>

            <!-- ── Group 2: Control, Output &amp; Status ────────────── -->
            <controls:ControlsPanelControl Grid.Row="1" />

        </Grid>

        <!-- ═══ Row 3: Footer ════════════════════════════════════════════════ -->
        <controls:FooterControl Grid.Row="3" />

    </Grid>

</Window>
