<Window xmlns="https://github.com/avaloniaui"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:controls="using:GlobalDataCreatorETL.UI.Views.Controls"
       xmlns:vm="using:GlobalDataCreatorETL.UI.ViewModels"
       x:Class="GlobalDataCreatorETL.UI.Views.MainWindow"
       Title="Global DataCreator ETL"
       Width="1280" Height="800"
       MinWidth="960" MinHeight="620"
       WindowStartupLocation="CenterScreen"
       Background="#F0F2F5">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- ═══ Row 0: Application Header ═══════════════════════════════════ -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#2235B0" Offset="0" />
                    <GradientStop Color="#3D5BD9" Offset="0.6" />
                    <GradientStop Color="#7B4FD6" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
            <Grid ColumnDefinitions="*,Auto" Margin="16 9">
                <!-- Left: App identity -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" Foreground="White" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock Text="Global DataCreator ETL"
                                   FontSize="15" FontWeight="Bold" Foreground="White" />
                        <TextBlock Text="Trade Data Extraction &amp; Excel Generation"
                                   FontSize="10" Foreground="#C8D4FF" />
                    </StackPanel>
                </StackPanel>
                <!-- Right: Live connection info -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="11" Foreground="#C8D4FF" VerticalAlignment="Center"
                               Text="{Binding ConnectionInfo.ServerName}" />
                    <TextBlock FontSize="11" Foreground="#6678CC" VerticalAlignment="Center" Text="|" />
                    <TextBlock FontSize="11" Foreground="#C8D4FF" VerticalAlignment="Center"
                               Text="{Binding ConnectionInfo.DatabaseName}" />
                    <TextBlock FontSize="11" Foreground="#6678CC" VerticalAlignment="Center" Text="|" />
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                 Fill="{Binding ConnectionInfo.StatusColor}" />
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="White"
                                   VerticalAlignment="Center"
                                   Text="{Binding ConnectionInfo.StatusMessage}" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Row 1: Menu Bar ══════════════════════════════════════════════ -->
        <Menu Grid.Row="1" Background="White"
              BorderBrush="#DDDDDD" BorderThickness="0 0 0 1"
              Padding="8 2">
            <MenuItem Header="_File">
                <MenuItem Header="Open Config Folder"  Command="{Binding OpenConfigFolderCommand}" />
                <MenuItem Header="Open Output Folder"  Command="{Binding OpenOutputFolderCommand}" />
                <Separator />
                <MenuItem Header="E_xit"               Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Clear All Filters"   Command="{Binding ResetCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Refresh Countries"   Command="{Binding RefreshCountriesCommand}" />
            </MenuItem>
            <MenuItem Header="_Settings">
                <MenuItem Header="Configuration…"      Command="{Binding OpenSettingsCommand}" />
            </MenuItem>
            <MenuItem Header="_About">
                <MenuItem Header="About Global DataCreator ETL" Command="{Binding OpenAboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- ═══ Row 2: Main Workspace (40:60) ════════════════════════════════ -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnDefinitions="4*,6*" Margin="8 6">

                <!-- ── Left Panel (40%) — Filter Parameters ───────────────── -->
                <Border Grid.Column="0" Classes="Card" Margin="0 0 4 0">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0" Classes="CardHeader" Text="Filter Parameters" />
                        <controls:InputFieldsControl Grid.Row="1" />
                    </Grid>
                </Border>

                <!-- ── Right Panel (60%) — Controls + Status stacked ─────── -->
                <Grid Grid.Column="1" RowDefinitions="Auto,6,*" Margin="4 0 0 0">

                    <Border Grid.Row="0" Classes="Card">
                        <controls:ControlsPanelControl />
                    </Border>

                    <controls:StatusPanelControl Grid.Row="2" />

                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- ═══ Row 3: Footer ════════════════════════════════════════════════ -->
        <controls:FooterControl Grid.Row="3" />

    </Grid>

</Window>
