<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:converters="using:GlobalDataCreatorETL.UI.Converters"
            xmlns:controls="using:GlobalDataCreatorETL.UI.Views.Controls"
            x:Class="GlobalDataCreatorETL.UI.Views.Controls.ControlsPanelControl">

    <UserControl.Resources>
        <converters:StringEqualConverter x:Key="StringEqual" />
    </UserControl.Resources>

    <!-- Card 1 (*): status panel | Card 2 (fixed 420px): all controls -->
    <Grid ColumnDefinitions="*,12,420">

        <!-- ════ Card 1 — Status Panel (fills left) ═════════════════════════ -->
        <controls:StatusPanelControl Grid.Column="0" />

        <!-- ════ Card 2 — Execution Controls ════════════════════════════════ -->
        <Border Grid.Column="2" Classes="Card">
            <StackPanel Spacing="8" VerticalAlignment="Top">

                <StackPanel Classes="CardHeaderRow">
                    <Viewbox Classes="HeaderIcon">
                        <Canvas Width="24" Height="24">
                            <Path Fill="#5B9BF5" Data="M4 14H8V22H4ZM10 10H14V22H10ZM16 6H20V22H16Z" />
                        </Canvas>
                    </Viewbox>
                    <TextBlock Classes="CardHeader" Text="Execution Controls" />
                </StackPanel>
                <Border Classes="Divider" />

                <!-- Row 1: Mode -->
                <StackPanel Spacing="3">
                    <TextBlock Classes="SectionTitle" Text="MODE" />
                    <Border Classes="SectionGroup">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <RadioButton Classes="FormRadio" Content="Export"
                                         IsChecked="{Binding IsExportMode}" />
                            <RadioButton Classes="FormRadio" Content="Import"
                                         IsChecked="{Binding IsImportMode}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Row 2: View | Stored Procedure -->
                <Grid ColumnDefinitions="*,8,*">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock Classes="SectionTitle" Text="VIEW" />
                        <TextBox Classes="FormInput" IsReadOnly="True"
                                 Text="{Binding SelectedView}"
                                 Foreground="#A4C4DE" FontWeight="SemiBold" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="3">
                        <TextBlock Classes="SectionTitle" Text="STORED PROCEDURE" />
                        <TextBox Classes="FormInput" IsReadOnly="True"
                                 Text="{Binding SelectedSP}"
                                 Foreground="#A4C4DE" FontWeight="SemiBold" />
                    </StackPanel>
                </Grid>

                <!-- Row 3: Buttons -->
                <Grid ColumnDefinitions="*,6,*,6,*">
                    <Button Grid.Column="0" Classes="PrimaryButton"
                            Command="{Binding StartCommand}"
                            HorizontalAlignment="Stretch"
                            Content="▶  Start" />
                    <Button Grid.Column="2" Classes="DangerButton"
                            Command="{Binding CancelCommand}"
                            HorizontalAlignment="Stretch"
                            Content="✕  Cancel"
                            IsEnabled="{Binding IsBusy}" />
                    <Button Grid.Column="4" Classes="ResetButton"
                            Command="{Binding ResetCommand}"
                            HorizontalAlignment="Stretch"
                            Content="↺  Reset" />
                </Grid>

            </StackPanel>
        </Border>

    </Grid>

</UserControl>
