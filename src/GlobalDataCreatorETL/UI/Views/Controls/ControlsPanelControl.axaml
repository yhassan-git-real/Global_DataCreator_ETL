<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            xmlns:converters="using:GlobalDataCreatorETL.UI.Converters"
            xmlns:controls="using:GlobalDataCreatorETL.UI.Views.Controls"
            x:Class="GlobalDataCreatorETL.UI.Views.Controls.ControlsPanelControl">

    <UserControl.Resources>
        <converters:StringEqualConverter x:Key="StringEqual" />
    </UserControl.Resources>

    <!-- Card 1 (*): status panel | Card 2 (fixed 420px): all controls -->
    <Grid ColumnDefinitions="*,12,420">

        <!-- ════ Card 1 — Status Panel (fills left) ═════════════════════════ -->
        <controls:StatusPanelControl Grid.Column="0" />

        <!-- ════ Card 2 — Execution Controls ════════════════════════════════ -->
        <Border Grid.Column="2" Classes="Card" Padding="0" ClipToBounds="True"
                VerticalAlignment="Top">
            <Grid RowDefinitions="Auto,2,Auto,1,Auto">

                <!-- ── Row 0: Header banner ──────────────────────────────── -->
                <Border Grid.Row="0" Background="#E617263C" Padding="14 10">
                    <Grid ColumnDefinitions="Auto,10,Auto">
                        <Viewbox Grid.Column="0" Width="24" Height="24"
                                 VerticalAlignment="Center" Stretch="Uniform">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#5B9BF5"
                                      Data="M4 14H8V22H4ZM10 10H14V22H10ZM16 6H20V22H16Z" />
                            </Canvas>
                        </Viewbox>
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                            <TextBlock Text="EXECUTION CONTROLS"
                                       FontSize="13" FontWeight="Bold" LetterSpacing="1.4"
                                       Foreground="#D4E8F8"
                                       FontFamily="Segoe UI, Inter, sans-serif" />
                            <TextBlock Text="ETL Operation Manager"
                                       FontSize="9" LetterSpacing="0.5"
                                       Foreground="#3A566E"
                                       FontFamily="Segoe UI, Inter, sans-serif" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ── Row 1: Blue gradient accent line ──────────────────── -->
                <Border Grid.Row="1" Height="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#4A8EE8" Offset="0" />
                            <GradientStop Color="#2C5CB0" Offset="0.4" />
                            <GradientStop Color="#1E2E44" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- ── Row 2: Mode + View/SP inputs ──────────────────────── -->
                <Border Grid.Row="2" Background="#CC131D2C" Padding="14 12">
                    <StackPanel Spacing="14">

                        <!-- MODE sub-section -->
                        <StackPanel Spacing="6">
                            <TextBlock Classes="SectionTitle" Text="MODE" />
                            <Border Background="#C00C1A2C" BorderBrush="#1E3050"
                                    BorderThickness="1" CornerRadius="6" Padding="12 8">
                                <StackPanel Orientation="Horizontal" Spacing="32">
                                    <RadioButton Classes="FormRadio" Content="Export"
                                                 IsChecked="{Binding IsExportMode}" />
                                    <RadioButton Classes="FormRadio" Content="Import"
                                                 IsChecked="{Binding IsImportMode}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- VIEW / STORED PROCEDURE sub-section -->
                        <Grid ColumnDefinitions="*,10,*">

                            <!-- VIEW -->
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Classes="SectionTitle" Text="VIEW" />
                                <Border Background="#C00E2038" BorderBrush="#2A4060"
                                        BorderThickness="1" CornerRadius="5" Padding="10 8">
                                    <TextBlock Text="{Binding SelectedView}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="#7AAACF"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </StackPanel>

                            <!-- STORED PROCEDURE -->
                            <StackPanel Grid.Column="2" Spacing="5">
                                <TextBlock Classes="SectionTitle" Text="STORED PROCEDURE" />
                                <Border Background="#C00E2038" BorderBrush="#2A4060"
                                        BorderThickness="1" CornerRadius="5" Padding="10 8">
                                    <TextBlock Text="{Binding SelectedSP}"
                                               FontFamily="Consolas" FontSize="11"
                                               Foreground="#7AAACF"
                                               TextTrimming="CharacterEllipsis" />
                                </Border>
                            </StackPanel>

                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ── Row 3: Gradient divider ───────────────────────────── -->
                <Border Grid.Row="3" Height="1">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Color="#244070" Offset="0" />
                            <GradientStop Color="#1A2E50" Offset="0.5" />
                            <GradientStop Color="#141E30" Offset="1" />
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- ── Row 4: Buttons ─────────────────────────────────────── -->
                <Border Grid.Row="4" Padding="14 16">
                    <Grid ColumnDefinitions="*,8,*,8,*">
                        <Button Grid.Column="0" Classes="PrimaryButton"
                                Command="{Binding StartCommand}"
                                HorizontalAlignment="Stretch"
                                Content="▶  Start" />
                        <Button Grid.Column="2" Classes="DangerButton"
                                Command="{Binding CancelCommand}"
                                HorizontalAlignment="Stretch"
                                Content="✕  Cancel"
                                IsEnabled="{Binding IsBusy}" />
                        <Button Grid.Column="4" Classes="ResetButton"
                                Command="{Binding ResetCommand}"
                                HorizontalAlignment="Stretch"
                                Content="↺  Reset" />
                    </Grid>
                </Border>

            </Grid>
        </Border>

    </Grid>

</UserControl>
