<UserControl xmlns="https://github.com/avaloniaui"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            x:Class="GlobalDataCreatorETL.UI.Views.Controls.StatusPanelControl">

    <Border Classes="Card" Padding="12" Margin="0">
        <Grid RowDefinitions="Auto,Auto,Auto,4,Auto,6,Auto,6,*">

            <!-- ── Row 0: Panel header ──────────────────────────────────────── -->
            <TextBlock Grid.Row="0" Classes="CardHeader" Text="Execution Log" />

            <!-- ── Row 1: Divider ───────────────────────────────────────────── -->
            <Border Grid.Row="1" Classes="Divider" />

            <!-- ── Row 2: Status bar ────────────────────────────────────────── -->
            <Grid Grid.Row="2" ColumnDefinitions="Auto,6,Auto,*,Auto,10,Auto"
                  MinHeight="20">
                <!-- Status dot -->
                <Ellipse Grid.Column="0" Classes="StatusDot"
                         Fill="{Binding SystemStatusColor}" />
                <!-- Running / Idle label -->
                <TextBlock Grid.Column="2"
                           FontWeight="SemiBold" FontSize="11"
                           Text="{Binding SystemStatusMessage}"
                           Foreground="{Binding SystemStatusColor}"
                           VerticalAlignment="Center" />
                <!-- Current step phase — fills remaining space -->
                <TextBlock Grid.Column="3" FontSize="11" Foreground="#777777"
                           Text="{Binding CurrentStepPhase}"
                           VerticalAlignment="Center" Margin="8 0 0 0"
                           TextTrimming="CharacterEllipsis" />
                <!-- Elapsed time -->
                <TextBlock Grid.Column="4" FontSize="11" Foreground="#555555"
                           Text="{Binding ElapsedTime}" FontFamily="Consolas"
                           VerticalAlignment="Center" />
                <!-- Row count -->
                <TextBlock Grid.Column="6" FontSize="11" Foreground="#1565C0"
                           FontWeight="SemiBold"
                           Text="{Binding RecordCount, StringFormat='{}{0:N0} rows'}"
                           VerticalAlignment="Center" />
            </Grid>

            <!-- ── Row 4: Progress bar ──────────────────────────────────────── -->
            <ProgressBar Grid.Row="4"
                         IsIndeterminate="{Binding IsBusy}"
                         Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Height="3" CornerRadius="2"
                         Foreground="#27AE60"
                         Background="#E8ECF0"
                         IsVisible="{Binding IsBusy}" />

            <!-- ── Row 6: Execution metrics ─────────────────────────────────── -->
            <Grid Grid.Row="6" ColumnDefinitions="Auto,*,20,Auto,*">
                <TextBlock Grid.Column="0" Classes="FieldLabel" Text="Country:" />
                <TextBlock Grid.Column="1" FontSize="11"
                           Text="{Binding SelectedCountry.Name}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="3" Classes="FieldLabel" Text="Output:" />
                <TextBlock Grid.Column="4" FontSize="11" Foreground="#1565C0"
                           Text="{Binding OutputFilePath}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
            </Grid>

            <!-- ── Row 8: Execution log ─────────────────────────────────────── -->
            <Border Grid.Row="8" Background="#F8FAFC"
                    BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="5" Padding="8 6">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding StatusLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           FontFamily="Consolas" FontSize="11"
                                           Foreground="#1E293B"
                                           TextWrapping="Wrap"
                                           Margin="0 1" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

        </Grid>
    </Border>

</UserControl>
