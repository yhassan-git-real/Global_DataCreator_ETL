<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GlobalDataCreatorETL.UI.Views.Controls.FooterControl">

    <Border Classes="FooterBar">
        <Grid ColumnDefinitions="Auto,*,Auto">

            <!-- Left: logo + copyright -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="7" VerticalAlignment="Center">
                <Border Width="18" Height="18" CornerRadius="4" ClipToBounds="True" VerticalAlignment="Center">
                    <Image Source="avares://GlobalDataCreatorETL/Asset/Logo.png" Stretch="UniformToFill" />
                </Border>
                <TextBlock Classes="FooterText"
                           Text="© 2026 Global DataCreator ETL  v1.0.0" VerticalAlignment="Center" />
            </StackPanel>

            <!-- Right: DB connection status -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{Binding ConnectionInfo.StatusColor}" />
                <TextBlock Classes="FooterText"
                           Text="{Binding ConnectionInfo.ServerName}" />
                <TextBlock Classes="FooterText" Text="|" />
                <TextBlock Classes="FooterText"
                           Text="{Binding ConnectionInfo.DatabaseName}" />
                <TextBlock Classes="FooterText" Text="|" />
                <TextBlock Classes="FooterText"
                           Text="{Binding ConnectionInfo.StatusMessage}" />
            </StackPanel>

        </Grid>
    </Border>

</UserControl>
