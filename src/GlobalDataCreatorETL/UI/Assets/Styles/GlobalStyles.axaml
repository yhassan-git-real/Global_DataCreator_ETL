<Styles xmlns="https://github.com/avaloniaui"
     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  DESIGN TOKENS — Slate Dusk (Mid-Dark, Pleasant)                    ║
    ║  Window   : #1A2235    Card    : #212D45    Border  : #2C3D58       ║
    ║  Section  : #16202E    Input   : #16202E    InpBor  : #2C3D58       ║
    ║  Text-1   : #BDD4E8    Text-2  : #9CB8D0    Muted   : #546E88       ║
    ║  Blue     : #5B9BF5    Purple  : #7C3AED    Green   : #16A34A       ║
    ║  Danger   : #DC2626    Footer  : #111929                            ║
    ╚══════════════════════════════════════════════════════════════════════╝
    -->

    <!-- ── Base font + default foreground ────────────────────────────────── -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
        <Setter Property="Foreground"  Value="#BDD4E8" />
    </Style>
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Card ──────────────────────────────────────────────────────────── -->
    <Style Selector="Border.Card">
        <Setter Property="Background"        Value="#D8212D45" />
        <Setter Property="CornerRadius"      Value="8" />
        <Setter Property="Padding"           Value="12" />
        <Setter Property="BorderBrush"       Value="#2C3D58" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="BoxShadow"         Value="0 2 8 0 #00000040" />
    </Style>

    <Style Selector="TextBlock.CardHeader">
        <Setter Property="FontSize"          Value="14" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#D4E8F8" />
        <Setter Property="Margin"            Value="0" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ── Card header row (icon + title wrapper) ────────────────────────── -->
    <Style Selector="StackPanel.CardHeaderRow">
        <Setter Property="Orientation"       Value="Horizontal" />
        <Setter Property="Spacing"           Value="6" />
        <Setter Property="Margin"            Value="0 2 0 10" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Viewbox.HeaderIcon">
        <Setter Property="Width"             Value="14" />
        <Setter Property="Height"            Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Stretch"           Value="Uniform" />
    </Style>

    <!-- ── Section divider ───────────────────────────────────────────────── -->
    <Style Selector="Border.Divider">
        <Setter Property="Height"            Value="1" />
        <Setter Property="Background"        Value="#233047" />
        <Setter Property="Margin"            Value="0 0 0 8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- ── Section Group ─────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize"          Value="10" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#5B9BF5" />
        <Setter Property="LetterSpacing"     Value="1" />
        <Setter Property="Margin"            Value="0 0 0 4" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <Style Selector="Border.SectionGroup">
        <Setter Property="Background"        Value="#CC16202E" />
        <Setter Property="BorderBrush"       Value="#2C3D58" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="10 6" />
    </Style>

    <!-- ── Labels ────────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.FieldLabel">
        <Setter Property="FontSize"          Value="10" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#4A6E8C" />
        <Setter Property="LetterSpacing"     Value="0.8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 0 4" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── TextBox — glass style ─────────────────────────────────────────── -->
    <Style Selector="TextBox.FormInput">
        <Setter Property="Height"                    Value="28" />
        <Setter Property="FontSize"                  Value="12" />
        <Setter Property="Padding"                   Value="8 0" />
        <Setter Property="VerticalContentAlignment"  Value="Center" />
        <Setter Property="CornerRadius"              Value="5" />
        <Setter Property="BorderBrush"               Value="#3898B4CC" />
        <Setter Property="BorderThickness"           Value="1" />
        <Setter Property="Background"                Value="#1AFFFFFF" />
        <Setter Property="Foreground"                Value="#BDD4E8" />
        <Setter Property="CaretBrush"                Value="#BDD4E8" />
        <Setter Property="SelectionBrush"            Value="#505B9BF5" />
        <Setter Property="FontFamily"                Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <!-- Watermark / placeholder text -->
    <Style Selector="TextBox.FormInput /template/ TextBlock">
        <Setter Property="Foreground" Value="#3A6080" />
    </Style>
    <!-- Inner border: transparent so our semi-opaque outer colour shows -->
    <Style Selector="TextBox.FormInput /template/ Border">
        <Setter Property="Background"  Value="Transparent" />
        <Setter Property="CornerRadius" Value="5" />
    </Style>
    <Style Selector="TextBox.FormInput:pointerover">
        <Setter Property="Background"  Value="#28FFFFFF" />
        <Setter Property="BorderBrush" Value="#5498B4CC" />
    </Style>
    <Style Selector="TextBox.FormInput:focus">
        <Setter Property="Background"  Value="#22FFFFFF" />
        <Setter Property="BorderBrush" Value="#5B9BF5" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- ── ComboBox — glass style ─────────────────────────────────────────── -->
    <Style Selector="ComboBox.FormComboBox">
        <Setter Property="Height"                Value="28" />
        <Setter Property="FontSize"              Value="12" />
        <Setter Property="Padding"               Value="8 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius"          Value="5" />
        <Setter Property="BorderBrush"           Value="#3898B4CC" />
        <Setter Property="BorderThickness"       Value="1" />
        <Setter Property="Background"            Value="#1AFFFFFF" />
        <Setter Property="Foreground"            Value="#BDD4E8" />
        <Setter Property="HorizontalAlignment"   Value="Stretch" />
        <Setter Property="MaxDropDownHeight"     Value="260" />
        <Setter Property="FontFamily"            Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="ComboBox.FormComboBox:pointerover">
        <Setter Property="Background"  Value="#28FFFFFF" />
        <Setter Property="BorderBrush" Value="#5498B4CC" />
    </Style>
    <Style Selector="ComboBox.FormComboBox:focus">
        <Setter Property="Background"  Value="#22FFFFFF" />
        <Setter Property="BorderBrush" Value="#5B9BF5" />
    </Style>

    <!-- ── RadioButton ───────────────────────────────────────────────────── -->
    <Style Selector="RadioButton.FormRadio">
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="Foreground"        Value="#B0C8E0" />
        <Setter Property="Margin"            Value="0 0 16 0" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Buttons ───────────────────────────────────────────────────────── -->

    <!-- START — emerald green -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background"        Value="#16A34A" />
        <Setter Property="Foreground"        Value="#ECFDF5" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="Bold" />
        <Setter Property="Height"            Value="36" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.PrimaryButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#16A34A" />
    </Style>
    <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#15803D" />
    </Style>
    <Style Selector="Button.PrimaryButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#14532D" />
    </Style>
    <Style Selector="Button.PrimaryButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#16A34A" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- CANCEL — red -->
    <Style Selector="Button.DangerButton">
        <Setter Property="Background"        Value="#DC2626" />
        <Setter Property="Foreground"        Value="#FEF2F2" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="Bold" />
        <Setter Property="Height"            Value="36" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.DangerButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#DC2626" />
    </Style>
    <Style Selector="Button.DangerButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#B91C1C" />
    </Style>
    <Style Selector="Button.DangerButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#991B1B" />
    </Style>
    <Style Selector="Button.DangerButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#DC2626" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- RESET — purple (dual-tone accent) -->
    <Style Selector="Button.ResetButton">
        <Setter Property="Background"        Value="#7C3AED" />
        <Setter Property="Foreground"        Value="#F5F3FF" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="Bold" />
        <Setter Property="Height"            Value="36" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.ResetButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#7C3AED" />
    </Style>
    <Style Selector="Button.ResetButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#6D28D9" />
    </Style>
    <Style Selector="Button.ResetButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#5B21B6" />
    </Style>
    <Style Selector="Button.ResetButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#7C3AED" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- OUTLINE — ghost with soft blue accent -->
    <Style Selector="Button.OutlineButton">
        <Setter Property="Background"        Value="Transparent" />
        <Setter Property="Foreground"        Value="#5B9BF5" />
        <Setter Property="BorderBrush"       Value="#2C3D58" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Height"            Value="28" />
        <Setter Property="CornerRadius"      Value="5" />
        <Setter Property="Padding"           Value="8 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.OutlineButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#1A2840" />
    </Style>

    <!-- ── Validation ────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.ValidationMessage">
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Foreground"        Value="#F87171" />
        <Setter Property="TextWrapping"      Value="Wrap" />
    </Style>

    <!-- ── Status dot ────────────────────────────────────────────────────── -->
    <Style Selector="Ellipse.StatusDot">
        <Setter Property="Width"             Value="7" />
        <Setter Property="Height"            Value="7" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 0 0" />
    </Style>

    <!-- ── Footer bar ────────────────────────────────────────────────────── -->
    <Style Selector="Border.FooterBar">
        <Setter Property="Background"        Value="#111929" />
        <Setter Property="Padding"           Value="16 0" />
        <Setter Property="Height"            Value="28" />
    </Style>

    <Style Selector="TextBlock.FooterText">
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Foreground"        Value="#4E6880" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 10 0" />
    </Style>

    <!-- ── Separator ─────────────────────────────────────────────────────── -->
    <Style Selector="Separator.FormSeparator">
        <Setter Property="Margin"            Value="0 6" />
        <Setter Property="Background"        Value="#233047" />
        <Setter Property="Height"            Value="1" />
    </Style>

    <!-- ── Window Control Buttons (custom title bar) ─────────────────────── -->
    <Style Selector="Button.WinCtrlBtn">
        <Setter Property="Background"                  Value="Transparent" />
        <Setter Property="BorderThickness"             Value="0" />
        <Setter Property="Foreground"                  Value="#8AAAC4" />
        <Setter Property="Width"                       Value="46" />
        <Setter Property="Height"                      Value="50" />
        <Setter Property="Padding"                     Value="0" />
        <Setter Property="CornerRadius"                Value="0" />
        <Setter Property="Cursor"                      Value="Arrow" />
        <Setter Property="HorizontalContentAlignment"  Value="Center" />
        <Setter Property="VerticalContentAlignment"    Value="Center" />
    </Style>
    <Style Selector="Button.WinCtrlBtn /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.WinCtrlBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#2C3D58" />
    </Style>
    <Style Selector="Button.WinCtrlBtn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#364B6E" />
    </Style>

    <!-- Close button: red highlight on hover -->
    <Style Selector="Button.WinCtrlBtn.CloseBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#E81123" />
    </Style>
    <Style Selector="Button.WinCtrlBtn.CloseBtn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#C50A0F" />
    </Style>

    <!-- ── Execution log — column headers ───────────────────────────────── -->
    <Style Selector="TextBlock.LogColumnHeader">
        <Setter Property="FontSize"          Value="9" />
        <Setter Property="FontWeight"        Value="Bold" />
        <Setter Property="Foreground"        Value="#4E7090" />
        <Setter Property="LetterSpacing"     Value="1.2" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Execution log — time cell ─────────────────────────────────────── -->
    <Style Selector="TextBlock.LogTime">
        <Setter Property="FontFamily"        Value="Consolas" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Foreground"        Value="#6898B4" />
    </Style>

    <!-- ── Execution log — stage badge ──────────────────────────────────── -->
    <Style Selector="Border.LogPhaseBadge">
        <Setter Property="CornerRadius"        Value="10" />
        <Setter Property="Padding"             Value="7 3" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment"   Value="Center" />
        <Setter Property="MinWidth"            Value="46" />
    </Style>

    <!-- ── Execution log — stage text ───────────────────────────────────── -->
    <Style Selector="TextBlock.LogPhase">
        <Setter Property="FontFamily"          Value="Consolas" />
        <Setter Property="FontSize"            Value="10" />
        <Setter Property="FontWeight"          Value="Bold" />
        <Setter Property="LetterSpacing"       Value="0.6" />
        <Setter Property="TextTrimming"        Value="CharacterEllipsis" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment"   Value="Center" />
    </Style>

    <!-- ── Execution log — detail text ──────────────────────────────────── -->
    <Style Selector="TextBlock.LogDetail">
        <Setter Property="FontFamily"        Value="Consolas" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="TextWrapping"      Value="Wrap" />
    </Style>

</Styles>
