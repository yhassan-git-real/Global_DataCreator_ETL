<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║  DESIGN TOKENS — Light Professional Theme                           ║
    ║  Background : #F1F5F9   Card      : #FFFFFF   Border  : #E2E8F0    ║
    ║  Text-1     : #0F172A   Text-2    : #64748B   Muted   : #94A3B8    ║
    ║  Primary    : #2563EB   Green     : #16A34A   Danger  : #DC2626    ║
    ║  Reset      : #64748B   Focus     : #2563EB   Shadow  : #0F172A12  ║
    ╚══════════════════════════════════════════════════════════════════════╝
    -->

    <!-- ── Base font ─────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="TextBox">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="ComboBox">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>
    <Style Selector="Button">
        <Setter Property="FontFamily" Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Card ──────────────────────────────────────────────────────────── -->
    <Style Selector="Border.Card">
        <Setter Property="Background"        Value="#FFFFFF" />
        <Setter Property="CornerRadius"      Value="8" />
        <Setter Property="Padding"           Value="12" />
        <Setter Property="BorderBrush"       Value="#E2E8F0" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="BoxShadow"         Value="0 1 4 0 #0F172A10" />
    </Style>

    <Style Selector="TextBlock.CardHeader">
        <Setter Property="FontSize"          Value="14" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#0F172A" />
        <Setter Property="Margin"            Value="0 2 0 10" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Section divider ───────────────────────────────────────────────── -->
    <Style Selector="Border.Divider">
        <Setter Property="Height"            Value="1" />
        <Setter Property="Background"        Value="#E8ECF0" />
        <Setter Property="Margin"            Value="0 0 0 8" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <!-- ── Section Group ─────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.SectionTitle">
        <Setter Property="FontSize"          Value="10" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#475569" />
        <Setter Property="LetterSpacing"     Value="1" />
        <Setter Property="Margin"            Value="0 0 0 4" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <Style Selector="Border.SectionGroup">
        <Setter Property="Background"        Value="#F8FAFC" />
        <Setter Property="BorderBrush"       Value="#E2E8F0" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="10 6" />
    </Style>

    <!-- ── Labels ────────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.FieldLabel">
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Foreground"        Value="#374151" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 0 2" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── TextBox ───────────────────────────────────────────────────────── -->
    <Style Selector="TextBox.FormInput">
        <Setter Property="Height"            Value="28" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="Padding"           Value="8 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius"      Value="5" />
        <Setter Property="BorderBrush"       Value="#D1D5DB" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="Background"        Value="#FFFFFF" />
        <Setter Property="Foreground"        Value="#111827" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <Style Selector="TextBox.FormInput:focus">
        <Setter Property="BorderBrush"       Value="#2563EB" />
        <Setter Property="BorderThickness"   Value="1.5" />
    </Style>

    <!-- ── ComboBox ──────────────────────────────────────────────────────── -->
    <Style Selector="ComboBox.FormComboBox">
        <Setter Property="Height"            Value="28" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="Padding"           Value="8 0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius"      Value="5" />
        <Setter Property="BorderBrush"       Value="#D1D5DB" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="Background"        Value="#FFFFFF" />
        <Setter Property="Foreground"        Value="#111827" />
        <Setter Property="HorizontalAlignment"  Value="Stretch" />
        <Setter Property="MaxDropDownHeight" Value="260" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <Style Selector="ComboBox.FormComboBox:focus">
        <Setter Property="BorderBrush"       Value="#2563EB" />
    </Style>

    <!-- ── RadioButton ───────────────────────────────────────────────────── -->
    <Style Selector="RadioButton.FormRadio">
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="Foreground"        Value="#374151" />
        <Setter Property="Margin"            Value="0 0 16 0" />
        <Setter Property="FontFamily"        Value="Segoe UI, Inter, sans-serif" />
    </Style>

    <!-- ── Buttons ───────────────────────────────────────────────────────── -->

    <!-- START — solid green -->
    <Style Selector="Button.PrimaryButton">
        <Setter Property="Background"        Value="#16A34A" />
        <Setter Property="Foreground"        Value="#FFFFFF" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Height"            Value="32" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.PrimaryButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#16A34A" />
    </Style>
    <Style Selector="Button.PrimaryButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#15803D" />
    </Style>
    <Style Selector="Button.PrimaryButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#14532D" />
    </Style>
    <Style Selector="Button.PrimaryButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#16A34A" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- CANCEL — solid red, always visible (never washed out) -->
    <Style Selector="Button.DangerButton">
        <Setter Property="Background"        Value="#DC2626" />
        <Setter Property="Foreground"        Value="#FFFFFF" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Height"            Value="32" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.DangerButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#DC2626" />
    </Style>
    <Style Selector="Button.DangerButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#B91C1C" />
    </Style>
    <Style Selector="Button.DangerButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#991B1B" />
    </Style>
    <!-- Disabled: keep red but dim — never goes grey/white -->
    <Style Selector="Button.DangerButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#DC2626" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- RESET — solid blue -->
    <Style Selector="Button.ResetButton">
        <Setter Property="Background"        Value="#2563EB" />
        <Setter Property="Foreground"        Value="#FFFFFF" />
        <Setter Property="FontSize"          Value="12" />
        <Setter Property="FontWeight"        Value="SemiBold" />
        <Setter Property="Height"            Value="32" />
        <Setter Property="CornerRadius"      Value="6" />
        <Setter Property="Padding"           Value="14 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="BorderThickness"   Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.ResetButton /template/ ContentPresenter">
        <Setter Property="Background"        Value="#2563EB" />
    </Style>
    <Style Selector="Button.ResetButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#1D4ED8" />
    </Style>
    <Style Selector="Button.ResetButton:pressed /template/ ContentPresenter">
        <Setter Property="Background"        Value="#1E40AF" />
    </Style>
    <Style Selector="Button.ResetButton:disabled /template/ ContentPresenter">
        <Setter Property="Background"        Value="#2563EB" />
        <Setter Property="Opacity"           Value="0.45" />
    </Style>

    <!-- OUTLINE — secondary ghost action -->
    <Style Selector="Button.OutlineButton">
        <Setter Property="Background"        Value="Transparent" />
        <Setter Property="Foreground"        Value="#2563EB" />
        <Setter Property="BorderBrush"       Value="#BFDBFE" />
        <Setter Property="BorderThickness"   Value="1" />
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Height"            Value="28" />
        <Setter Property="CornerRadius"      Value="5" />
        <Setter Property="Padding"           Value="8 0" />
        <Setter Property="Cursor"            Value="Hand" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment"   Value="Center" />
    </Style>
    <Style Selector="Button.OutlineButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background"        Value="#EFF6FF" />
    </Style>

    <!-- ── Validation ────────────────────────────────────────────────────── -->
    <Style Selector="TextBlock.ValidationMessage">
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Foreground"        Value="#DC2626" />
        <Setter Property="TextWrapping"      Value="Wrap" />
    </Style>

    <!-- ── Status dot ────────────────────────────────────────────────────── -->
    <Style Selector="Ellipse.StatusDot">
        <Setter Property="Width"             Value="7" />
        <Setter Property="Height"            Value="7" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 0 0" />
    </Style>

    <!-- ── Footer bar ────────────────────────────────────────────────────── -->
    <Style Selector="Border.FooterBar">
        <Setter Property="Background"        Value="#1E293B" />
        <Setter Property="Padding"           Value="16 0" />
        <Setter Property="Height"            Value="28" />
    </Style>

    <Style Selector="TextBlock.FooterText">
        <Setter Property="FontSize"          Value="11" />
        <Setter Property="Foreground"        Value="#94A3B8" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin"            Value="0 0 10 0" />
    </Style>

    <!-- ── Separator ─────────────────────────────────────────────────────── -->
    <Style Selector="Separator.FormSeparator">
        <Setter Property="Margin"            Value="0 6" />
        <Setter Property="Background"        Value="#E2E8F0" />
        <Setter Property="Height"            Value="1" />
    </Style>

    <!-- ── Window Control Buttons (custom title bar) ─────────────────────── -->
    <Style Selector="Button.WinCtrlBtn">
        <Setter Property="Background"                  Value="Transparent" />
        <Setter Property="BorderThickness"             Value="0" />
        <Setter Property="Foreground"                  Value="White" />
        <Setter Property="Width"                       Value="46" />
        <Setter Property="Height"                      Value="50" />
        <Setter Property="Padding"                     Value="0" />
        <Setter Property="CornerRadius"                Value="0" />
        <Setter Property="Cursor"                      Value="Arrow" />
        <Setter Property="HorizontalContentAlignment"  Value="Center" />
        <Setter Property="VerticalContentAlignment"    Value="Center" />
    </Style>
    <Style Selector="Button.WinCtrlBtn /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.WinCtrlBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#33FFFFFF" />
    </Style>
    <Style Selector="Button.WinCtrlBtn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#55FFFFFF" />
    </Style>

    <!-- Close button: red highlight on hover -->
    <Style Selector="Button.WinCtrlBtn.CloseBtn:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="#E81123" />
    </Style>
    <Style Selector="Button.WinCtrlBtn.CloseBtn:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="#C50A0F" />
    </Style>

</Styles>
